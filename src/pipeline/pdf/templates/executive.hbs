<div class="section">
  <h2 class="section-title">Vezetői összefoglaló</h2>

  <div class="exec-scores">
    <table class="data-table">
      <thead>
        <tr><th>Dimenzió</th><th>Pontszám</th></tr>
      </thead>
      <tbody>
        <tr><td>GEO / SEO</td><td style="color: {{scoreColor geo_score}}"><strong>{{geo_score}}/100</strong></td></tr>
        <tr><td>Marketing</td><td style="color: {{scoreColor marketing_score}}"><strong>{{marketing_score}}/100</strong></td></tr>
        <tr><td>Jogi megfelelőség</td><td style="color: {{scoreColor compliance_score}}"><strong>{{compliance_score}}/100 ({{compliance_grade}})</strong></td></tr>
        {{#if sales_score}}<tr><td>Sales</td><td style="color: {{scoreColor sales_score}}"><strong>{{sales_score}}/100</strong></td></tr>{{/if}}
      </tbody>
    </table>
  </div>

  <h3>Erősségek</h3>
  <ul>{{#each strengths}}<li>{{this}}</li>{{/each}}</ul>

  <h3>Legnagyobb hiányosságok</h3>
  <ul>{{#each biggest_gaps}}<li>{{this}}</li>{{/each}}</ul>

  <h3>Leggyorsabb javítások</h3>
  <ul>{{#each fastest_fixes}}<li>{{this}}</li>{{/each}}</ul>
</div>
